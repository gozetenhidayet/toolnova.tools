{
  "manifest_version": 3,
  "name": "toolnova.tools — Free Online Tools",
  "short_name": "toolnova",
  "version": "1.0",
  "description": "Quick access to free online tools: QR Code, Age Calculator, BMI, Currency Converter and more. No signup needed.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "toolnova.tools"
  },
  "context_menus": true,
  "permissions": [
    "contextMenus",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
